---

<div class:list={["flex items-center gap-4", className]}>
  {
    socials.map((social) => (
      <a
        href={social.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${social.name} (nouvelle fenêtre)`}
        class="text-white/50 transition-colors hover:text-orange"
      >
        {social.fill ? (
          <svg
            class={iconClass}
            viewBox={social.viewBox}
            fill="currentColor"
            aria-hidden="true"
            set:html={social.icon}
          />
        ) : (
          <svg
            class={iconClass}
            viewBox={social.viewBox}
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            set:html={social.icon}
          />
        )}
      </a>
    ))
  }
</div>
