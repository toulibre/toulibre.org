---
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
  { href: "/#capitole-du-libre", label: "Capitole du Libre" },
  { href: "/evenements", label: "Événements" },
  { href: "/#a-propos", label: "À propos" },
  { href: "/#communaute", label: "Communauté" },
];
---

<header
  class="fixed top-0 z-50 w-full border-b border-white/10 bg-black/90 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3"
    aria-label="Navigation principale"
  >
    <a href="/#" class="flex items-center gap-2" aria-label="Toulibre — Accueil">
      <img
        src="/static/img/logo_toulibre.svg"
        alt="Toulibre"
        class="h-8 w-auto"
        width="111"
        height="32"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden gap-6 md:flex" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-white/70 transition-colors hover:text-orange"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <ThemeToggle />

    <!-- Mobile menu button -->
    <button
      type="button"
      class="text-white/70 hover:text-orange md:hidden"
      aria-label="Ouvrir le menu de navigation"
      aria-expanded="false"
      data-menu-toggle
    >
      <svg
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
    </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div class="hidden md:hidden" data-mobile-menu>
    <ul class="space-y-1 px-4 pb-4" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block rounded-lg px-3 py-2 text-sm text-white/70 transition-colors hover:bg-white/10 hover:text-orange"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close menu on link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
