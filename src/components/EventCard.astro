---
interface Props {
  title: string;
  date: string;
  endDate?: string;
  location: string;
  description: string;
  type: string;
  url?: string;
  featured?: boolean;
}

const { title, date, endDate, location, description, type, url, featured = false } = Astro.props;

// Stable, shareable slug derived from the title and the date (e.g. "atelier-blender-2026-06-27").
function slugify(value: string): string {
  return value
    .normalize("NFD")
    .replace(/[̀-ͯ]/g, "") // strip combining diacritical marks
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}
const slug = `${slugify(title)}-${date.slice(0, 10)}`;

const eventDate = new Date(date);
const day = eventDate.toLocaleDateString("fr-FR", { day: "numeric" });
const month = eventDate.toLocaleDateString("fr-FR", { month: "short" }).replace(".", "");
const time = eventDate.toLocaleDateString("fr-FR", {
  weekday: "long",
  day: "numeric",
  month: "long",
  year: "numeric",
}) + " à " + eventDate.toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" });

const typeLabels: Record<string, string> = {
  qjelt: "QJeLT",
  permanence: "Permanence",
  atelier: "Atelier",
  projection: "Projection",
  conference: "Conférence",
};

const typeColors: Record<string, string> = {
  qjelt: "bg-orange/20 text-orange",
  permanence: "bg-orange/15 text-orange",
  atelier: "bg-cream text-brown",
  projection: "bg-orange/10 text-orange",
  conference: "bg-brown/10 text-brown",
};
---

<div
  id={slug}
  data-event-card
  data-event-slug={slug}
  data-event-date={date}
  data-event-end-date={endDate ?? date}
  class:list={[
    "event-card scroll-mt-28 rounded-2xl border border-content/10 bg-card",
    featured ? "p-6 md:p-8" : "p-5",
  ]}
>
  <div class="flex gap-4">
    <!-- Date badge -->
    <div
      class="flex h-14 w-14 shrink-0 flex-col items-center justify-center rounded-xl bg-black text-white"
    >
      <span class:list={["js-event-day font-heading font-bold leading-none", featured ? "text-xl" : "text-lg"]}>{day}</span>
      <span class="text-xs uppercase text-white/70">{month}</span>
    </div>

    <div class="min-w-0 flex-1">
      <!-- Type badge + direct link -->
      <div class="mb-2 flex items-start justify-between gap-2">
        <span
          class:list={[
            "inline-block rounded-full px-2.5 py-0.5 text-xs font-medium",
            typeColors[type] || "bg-content/5 text-content",
          ]}
        >
          {typeLabels[type] || type}
        </span>

        <span class="js-event-link-wrap relative shrink-0">
          <a
            href={`#${slug}`}
            class="js-event-link inline-flex h-7 w-7 items-center justify-center rounded-lg text-content/40 transition-colors hover:bg-content/5 hover:text-orange"
            data-event-slug={slug}
            aria-label="Mettre en avant cet événement et copier son lien"
            title="Copier le lien vers cet événement"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
          </a>
          <span
            class="js-link-feedback pointer-events-none absolute right-0 top-full z-10 mt-1 whitespace-nowrap rounded-md bg-black px-2 py-1 text-xs text-white opacity-0 transition-opacity duration-200"
            aria-hidden="true"
          >
            Lien copié
          </span>
        </span>
      </div>

      <!-- Title + details -->
      <details class="group">
        <summary
          class:list={[
            "js-event-title font-heading font-semibold text-content cursor-pointer list-none",
            featured ? "text-xl md:text-2xl" : "text-base",
          ]}
        >
          <h3 class="inline">
            {title}
            <span class="ml-1 inline-block text-content/40 transition-transform group-open:rotate-90">&#9654;</span>
          </h3>
        </summary>

        <div class="mt-3 text-sm leading-relaxed text-content/70">
          <p>{description}</p>
          {url && (
            <p class="mt-2">
              <a href={url} target="_blank" rel="noopener noreferrer" class="font-medium text-orange underline hover:text-orange/80">
                Voir l'événement &rarr;
              </a>
            </p>
          )}
        </div>
      </details>

      <!-- Time & location -->
      <p class="mt-1 text-sm text-content/60">
        <time datetime={date}>{time}</time>
      </p>
      <p class="text-sm text-content/60">{location}</p>
    </div>
  </div>
</div>
