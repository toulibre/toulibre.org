---
import Layout from "../layouts/Layout.astro";
import EventCard from "../components/EventCard.astro";
import events from "../data/events.json";

const title = "Événements — Toulibre";
const description =
  "Tous les événements de l'association Toulibre : repas mensuels QJeLT, permanences GNU/Linux, ateliers, conférences et projections autour du logiciel libre à Toulouse.";

const now = new Date();

const upcomingEvents = events
  .filter((e) => new Date(e.date) >= now)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastEvents = events
  .filter((e) => new Date(e.date) < now)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const featuredEvent = upcomingEvents[0];
const otherUpcoming = upcomingEvents.slice(1);
---

<Layout title={title} description={description}>
  <article class="mx-auto max-w-4xl px-4 pb-16 pt-32">
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-1 text-sm text-content/50 transition-colors hover:text-orange"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m12 19-7-7 7-7"></path>
        <path d="M19 12H5"></path>
      </svg>
      Retour à l'accueil
    </a>

    <h1 class="font-heading text-3xl font-bold text-content md:text-4xl">
      Événements
    </h1>
    <p class="mt-3 text-lg text-content/60">
      Retrouvez tous nos rendez-vous, passés et à venir, autour du logiciel libre à Toulouse.
    </p>

    <!-- ====== UPCOMING EVENTS ====== -->
    <section class="mt-12" aria-labelledby="upcoming-heading">
      <h2 id="upcoming-heading" class="font-heading text-xl font-semibold text-content">
        Prochains événements
      </h2>

      {
        upcomingEvents.length > 0 ? (
          <div class="mt-6 space-y-4">
            {featuredEvent && <EventCard {...featuredEvent} featured />}
            {otherUpcoming.length > 0 && (
              <div class="grid gap-4 md:grid-cols-2">
                {otherUpcoming.map((event) => (
                  <EventCard {...event} />
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="mt-6 rounded-2xl border border-content/10 bg-page-alt p-8 text-center">
            <p class="text-content/60">
              Pas d'événement programmé pour le moment. Suivez-nous sur nos réseaux pour
              ne rien rater !
            </p>
          </div>
        )
      }
    </section>

    <!-- ====== PAST EVENTS ====== -->
    {
      pastEvents.length > 0 && (
        <section class="mt-16" aria-labelledby="past-heading">
          <h2 id="past-heading" class="font-heading text-xl font-semibold text-content">
            Événements passés
          </h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {pastEvents.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </section>
      )
    }

  </article>
</Layout>
