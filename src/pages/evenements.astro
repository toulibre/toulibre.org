---
import Layout from "../layouts/Layout.astro";
import EventCard from "../components/EventCard.astro";
import events from "../data/events.json";

const title = "Événements — Toulibre";
const description =
  "Tous les événements de l'association Toulibre : repas mensuels QJeLT, permanences GNU/Linux, ateliers, conférences et projections autour du logiciel libre à Toulouse.";
---

<Layout title={title} description={description}>
  <article class="mx-auto max-w-4xl px-4 pb-16 pt-32">
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-1 text-sm text-content/50 transition-colors hover:text-orange"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m12 19-7-7 7-7"></path>
        <path d="M19 12H5"></path>
      </svg>
      Retour à l'accueil
    </a>

    <h1 class="font-heading text-3xl font-bold text-content md:text-4xl">
      Événements
    </h1>
    <p class="mt-3 text-lg text-content/60">
      Retrouvez tous nos rendez-vous, passés et à venir, autour du logiciel libre à Toulouse.
    </p>

    <!-- ====== JS-ENABLED: highlighted event (deep link target) ====== -->
    <section id="highlight-section" class="mt-10 scroll-mt-28" aria-labelledby="highlight-heading" hidden>
      <div class="flex items-center justify-between gap-2">
        <h2 id="highlight-heading" class="font-heading text-xl font-semibold text-orange">
          Événement sélectionné
        </h2>
        <button
          type="button"
          id="highlight-close"
          class="inline-flex items-center gap-1 text-sm text-content/50 transition-colors hover:text-orange"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
          Fermer
        </button>
      </div>
      <div id="highlight-slot" class="mt-4"></div>
    </section>

    <!-- ====== NO-JS FALLBACK: all events visible, unsorted ====== -->
    <section id="events-fallback" data-nojs class="mt-12" aria-labelledby="fallback-heading">
      <h2 id="fallback-heading" class="font-heading text-xl font-semibold text-content">
        Tous les événements
      </h2>
      <div id="events-pool" class="mt-6 grid gap-4 md:grid-cols-2">
        {events.map((event) => <EventCard {...event} />)}
      </div>
    </section>

    <!-- ====== JS-ENABLED: upcoming events ====== -->
    <section id="upcoming-section" class="mt-12" aria-labelledby="upcoming-heading" hidden>
      <h2 id="upcoming-heading" class="font-heading text-xl font-semibold text-content">
        Prochains événements
      </h2>
      <div id="upcoming-featured-slot" class="mt-6 space-y-4"></div>
      <div id="upcoming-other-slot" class="mt-4 grid gap-4 md:grid-cols-2"></div>
      <div id="upcoming-empty" class="mt-6 rounded-2xl border border-content/10 bg-page-alt p-8 text-center" hidden>
        <p class="text-content/60">
          Pas d'événement programmé pour le moment. Suivez-nous sur nos réseaux pour
          ne rien rater !
        </p>
      </div>
    </section>

    <!-- ====== JS-ENABLED: past events ====== -->
    <section id="past-section" class="mt-16" aria-labelledby="past-heading" hidden>
      <h2 id="past-heading" class="font-heading text-xl font-semibold text-content">
        Événements passés
      </h2>
      <div id="past-slot" class="mt-6 grid gap-4 md:grid-cols-2"></div>
    </section>

  </article>

  <script is:inline>
    (function () {
      const fallback = document.getElementById("events-fallback");
      const pool = document.getElementById("events-pool");
      const upcomingSection = document.getElementById("upcoming-section");
      const pastSection = document.getElementById("past-section");
      const featuredSlot = document.getElementById("upcoming-featured-slot");
      const otherSlot = document.getElementById("upcoming-other-slot");
      const pastSlot = document.getElementById("past-slot");
      const emptyMsg = document.getElementById("upcoming-empty");
      const highlightSection = document.getElementById("highlight-section");
      const highlightSlot = document.getElementById("highlight-slot");
      const highlightClose = document.getElementById("highlight-close");

      if (!pool || !fallback) return;

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const cards = Array.from(pool.querySelectorAll("[data-event-card]"));
      const upcoming = [];
      const past = [];
      for (const card of cards) {
        const endStr = card.dataset.eventEndDate || card.dataset.eventDate;
        const end = new Date(endStr);
        end.setHours(0, 0, 0, 0);
        (end >= today ? upcoming : past).push(card);
      }
      upcoming.sort((a, b) =>
        new Date(a.dataset.eventDate).getTime() - new Date(b.dataset.eventDate).getTime()
      );
      past.sort((a, b) =>
        new Date(b.dataset.eventDate).getTime() - new Date(a.dataset.eventDate).getTime()
      );

      function applyFeatured(card) {
        card.classList.remove("p-5");
        card.classList.add("p-6", "md:p-8");
        const day = card.querySelector(".js-event-day");
        if (day) {
          day.classList.remove("text-lg");
          day.classList.add("text-xl");
        }
        const title = card.querySelector(".js-event-title");
        if (title) {
          title.classList.remove("text-base");
          title.classList.add("text-xl", "md:text-2xl");
        }
      }

      fallback.hidden = true;
      upcomingSection.hidden = false;

      if (upcoming.length > 0) {
        const [first, ...rest] = upcoming;
        applyFeatured(first);
        featuredSlot.appendChild(first);
        for (const card of rest) otherSlot.appendChild(card);
      } else {
        emptyMsg.hidden = false;
      }

      if (past.length > 0) {
        pastSection.hidden = false;
        for (const card of past) pastSlot.appendChild(card);
      }

      // ---- Highlight / deep-link handling ----
      function cardBySlug(slug) {
        return cards.find((c) => c.dataset.eventSlug === slug);
      }

      function flashCopied(link) {
        const wrap = link.closest(".js-event-link-wrap");
        const fb = wrap && wrap.querySelector(".js-link-feedback");
        if (!fb) return;
        fb.classList.remove("opacity-0");
        fb.classList.add("opacity-100");
        clearTimeout(fb._timer);
        fb._timer = setTimeout(() => {
          fb.classList.remove("opacity-100");
          fb.classList.add("opacity-0");
        }, 1500);
      }

      function bindLinks(root) {
        for (const link of root.querySelectorAll(".js-event-link")) {
          if (link.dataset.bound) continue;
          link.dataset.bound = "1";
          link.addEventListener("click", (e) => {
            e.preventDefault();
            const slug = link.dataset.eventSlug;
            if (!slug) return;
            history.replaceState(null, "", "#" + slug);
            showHighlight(slug, true);
            const url = location.origin + location.pathname + "#" + slug;
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(url).then(() => flashCopied(link)).catch(() => {});
            }
          });
        }
      }

      function showHighlight(slug, scroll) {
        const source = cardBySlug(slug);
        if (!source) return false;
        const clone = source.cloneNode(true);
        clone.removeAttribute("id"); // avoid duplicating the source card's id
        for (const l of clone.querySelectorAll(".js-event-link")) delete l.dataset.bound;
        applyFeatured(clone);
        // Make the selected event clearly stand out from the regular cards.
        clone.classList.remove("border", "border-content/10");
        clone.classList.add("border-2", "border-orange", "shadow-lg", "shadow-orange/20");
        const details = clone.querySelector("details");
        if (details) details.open = true;
        highlightSlot.replaceChildren(clone);
        highlightSection.hidden = false;
        bindLinks(highlightSlot);
        if (scroll) highlightSection.scrollIntoView({ behavior: "smooth", block: "start" });
        return true;
      }

      function clearHighlight() {
        highlightSlot.replaceChildren();
        highlightSection.hidden = true;
        history.replaceState(null, "", location.pathname + location.search);
      }

      if (highlightClose) highlightClose.addEventListener("click", clearHighlight);
      bindLinks(document);

      window.addEventListener("hashchange", () => {
        const slug = decodeURIComponent(location.hash.slice(1));
        if (slug) showHighlight(slug, true);
        else clearHighlight();
      });

      // Open the highlight immediately when arriving with a #slug deep link.
      const initialSlug = decodeURIComponent(location.hash.slice(1));
      if (initialSlug) showHighlight(initialSlug, true);
    })();
  </script>
</Layout>
