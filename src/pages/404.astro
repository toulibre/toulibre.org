---
import Layout from "../layouts/Layout.astro";
import ToulibreName from "../components/ToulibreName.astro";

const title = "Page introuvable — Toulibre";
const description = "La page que vous cherchez n'existe pas ou a été déplacée.";
---

<Layout title={title} description={description}>
  <div class="flex min-h-[80vh] items-center justify-center px-4 pb-16 pt-16">
    <div class="text-center">
      <p class="font-heading text-8xl font-bold text-orange">404</p>
      <h1 class="mt-4 font-heading text-2xl font-bold text-content">
        Page introuvable
      </h1>
      <p class="mt-3 max-w-md text-content/60">
        La page que vous cherchez n'existe pas, a été déplacée ou est
        temporairement indisponible.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-orange px-6 py-3 font-heading text-sm font-semibold text-black transition-colors hover:bg-yellow"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          Retour à l'accueil
        </a>
        <a
          href="/evenements"
          class="inline-flex items-center gap-2 rounded-full border border-content/20 px-6 py-3 font-heading text-sm font-semibold text-content transition-colors hover:border-orange hover:text-orange"
        >
          Voir les événements
        </a>
      </div>
    </div>
  </div>
</Layout>
