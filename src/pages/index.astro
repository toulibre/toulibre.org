---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import EventCard from "../components/EventCard.astro";
import ToulibreName from "../components/ToulibreName.astro";
import SocialLinks from "../components/SocialLinks.astro";
import ObfuscatedEmail from "../components/ObfuscatedEmail.astro";
import events from "../data/events.json";

const title = "Toulibre — Logiciel Libre en Occitanie";
const description =
  "Toulibre est une association loi 1901 basée à Toulouse qui promeut le Logiciel Libre et la culture libre en Occitanie. Événements, ateliers, conférences et Capitole du Libre.";

const sortedEvents = events
  .filter((e) => new Date(e.date) >= new Date())
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const featuredEvent = sortedEvents[0];
const nextEvents = sortedEvents.slice(1, 3);
---

<Layout title={title} description={description}>
  <!-- ====== HERO ====== -->
  <section
    id="hero"
    class="relative flex min-h-screen items-center justify-center bg-black px-4 pt-16"
    aria-label="Accueil"
  >
    <!-- Background photo -->
    <img
      src="/static/img/hero-bg.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <!-- Dark overlay for readability -->
    <div
      class="absolute inset-0 bg-black/60 bg-gradient-to-b from-black/65 via-black/55 to-black/75"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 mx-auto max-w-4xl text-center">
      <img
        src="/static/img/logo_toulibre.svg"
        alt="Logo Toulibre"
        class="mx-auto mb-8 h-24 w-auto md:h-32"
        width="475"
        height="137"
      />

      <h1 class="font-heading text-4xl font-bold text-white md:text-5xl lg:text-6xl">
        Promouvoir, développer et<br />
        démocratiser le
        <span class="text-orange">Logiciel Libre</span><br />
        en Occitanie
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg text-white/60">
        <ToulibreName /> est une association toulousaine qui rassemble
        utilisateur·ice·s, développeur·se·s et curieux·ses autour du logiciel libre
        et de la culture libre depuis 2006.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/evenements"
          class="inline-flex items-center gap-2 rounded-full bg-orange px-6 py-3 font-heading text-sm font-semibold text-black transition-colors hover:bg-yellow"
        >
          Nos événements
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="https://capitoledulibre.org"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3 font-heading text-sm font-semibold text-white transition-colors hover:border-orange hover:text-orange"
        >
          Capitole du Libre
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2" aria-hidden="true">
      <div class="flex h-8 w-5 items-start justify-center rounded-full border-2 border-white/20 p-1">
        <div class="h-1.5 w-1 animate-bounce rounded-full bg-white/40"></div>
      </div>
    </div>
  </section>

  <!-- ====== CAPITOLE DU LIBRE ====== -->
  <Section
    id="capitole-du-libre"
    title="Capitole du Libre"
    subtitle="Notre événement phare, un week-end entier dédié au Logiciel Libre et à la culture libre."
    class="bg-page-alt"
  >
    <div class="grid gap-8 md:grid-cols-2">
      <div>
        <p class="leading-relaxed text-content/80">
          Chaque automne, <ToulibreName /> organise le <strong>Capitole du Libre</strong>
          à l'<strong>INP-ENSEEIHT</strong> de Toulouse. Depuis 2011, cet événement
          gratuit et ouvert à tous·tes est devenu un rendez-vous incontournable de
          la communauté du libre dans le Sud de la France, avec <strong>plus de 1200
          participant·e·s</strong> en 2024.
        </p>

        <div class="mt-6 grid grid-cols-2 gap-4 text-center">
          <div class="rounded-xl bg-card p-4">
            <p class="font-heading text-2xl font-bold text-orange">100+</p>
            <p class="text-sm text-content/60">Conférences</p>
          </div>
          <div class="rounded-xl bg-card p-4">
            <p class="font-heading text-2xl font-bold text-orange">20+</p>
            <p class="text-sm text-content/60">Ateliers</p>
          </div>
          <div class="rounded-xl bg-card p-4">
            <p class="font-heading text-2xl font-bold text-orange">12</p>
            <p class="text-sm text-content/60">Éditions</p>
          </div>
          <div class="rounded-xl bg-card p-4">
            <p class="font-heading text-2xl font-bold text-orange">1200</p>
            <p class="text-sm text-content/60">Participant·e·s en 2024</p>
          </div>
        </div>
      </div>

      <div>
        <h3 class="font-heading text-lg font-semibold text-content">Ce qu'on y trouve</h3>
        <ul class="mt-3 space-y-2 text-content/70" role="list">
          {
            [
              "Conférences sur le développement web, C++, DevOps, embarqué, création graphique libre",
              "Ateliers pratiques pour tous les niveaux",
              "Village associatif avec les acteurs du libre",
              "Espace « Adoptez le logiciel libre » pour les débutant·e·s",
              "LAN Party et jeux libres",
              "Cocktail du samedi soir",
              "Thèmes sociétaux : enjeux du numérique ouvert",
            ].map((item) => (
              <li class="flex gap-2">
                <svg
                  class="mt-1 h-4 w-4 shrink-0 text-orange"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="https://capitoledulibre.org"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-black px-5 py-2.5 font-heading text-sm font-semibold text-white transition-colors hover:bg-black/80"
          >
            Site officiel
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" x2="21" y1="14" y2="3" />
            </svg>
          </a>
          <a
            href="https://videos.capitoledulibre.org"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-content/20 px-5 py-2.5 font-heading text-sm font-semibold text-content transition-colors hover:border-orange hover:text-orange"
          >
            Vidéos des éditions passées
          </a>
        </div>
      </div>
    </div>
  </Section>

  <!-- ====== UPCOMING EVENTS ====== -->
  <Section
    id="evenements"
    title="Prochains événements"
    subtitle="Retrouvez-nous lors de nos prochains rendez-vous, ouverts à toutes et tous."
  >
    {
      featuredEvent ? (
        <div class="space-y-4">
          <EventCard {...featuredEvent} featured />
          {nextEvents.length > 0 && (
            <div class="grid gap-4 md:grid-cols-2">
              {nextEvents.map((event) => (
                <EventCard {...event} />
              ))}
            </div>
          )}
        </div>
      ) : (
        <div class="rounded-2xl border border-content/10 bg-page-alt p-8 text-center">
          <p class="text-content/60">
            Pas d'événement programmé pour le moment. Suivez-nous sur nos réseaux pour
            ne rien rater !
          </p>
        </div>
      )
    }

    <div class="mt-8 text-center">
      <a
        href="/evenements"
        class="inline-flex items-center gap-1 text-sm font-medium text-orange transition-colors hover:text-brown"
      >
        Voir tous les événements
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </Section>

  <!-- ====== ABOUT ====== -->
  <Section
    id="a-propos"
    title="Qui sommes-nous ?"
    subtitle="Une association d'éducation populaire au service du logiciel libre depuis 2006."
    class="bg-page-alt"
  >
    <div class="grid gap-8 md:grid-cols-2">
      <div class="space-y-4 leading-relaxed text-content/80">
        <p>
          <ToulibreName /> est une <strong>association loi 1901</strong> qui rassemble
          utilisateur·ice·s et développeur·se·s de Logiciels Libres
          de la région toulousaine. Fondée en 2006 (elle existe de fait depuis 2005),
          elle s'inscrit dans une perspective d'<strong>éducation populaire</strong>.
        </p>
        <p>
          Son objet est d'organiser des actions visant à promouvoir, développer et
          démocratiser les Logiciels Libres en région Occitanie. L'association s'intéresse
          également à la promotion des œuvres sous licence libre.
        </p>
        <p>
          Toutes nos activités sont <strong>ouvertes à tous·tes</strong>, membres ou non.
          Que vous soyez débutant·e curieux·se ou vétéran·e du libre, vous êtes les
          bienvenu·e·s !
        </p>
        <a
          href="/association"
          class="inline-flex items-center gap-1 text-sm font-medium text-orange transition-colors hover:text-brown"
        >
          En savoir plus sur l'association
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="space-y-6">
        <!-- Commitments -->
        <div class="rounded-2xl border border-content/10 bg-card p-6">
          <h3 class="font-heading text-lg font-semibold text-content">Nos engagements</h3>
          <ul class="mt-3 space-y-2 text-sm text-content/70" role="list">
            {
              [
                "Membre de l'APRIL",
                "Signataire de la charte de laïcité du conseil départemental de la Haute-Garonne",
                "Signataire du contrat d'engagement républicain (depuis septembre 2023)",
              ].map((item) => (
                <li class="flex gap-2">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-orange"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
          <a
            href="/static/pdf/statuts-association-toulibre.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-orange transition-colors hover:text-brown"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
              <polyline points="14 2 14 8 20 8" />
            </svg>
            Statuts de l'association (PDF)
          </a>
        </div>

        <!-- Membership -->
        <div class="rounded-2xl border border-orange/30 bg-orange/5 p-6">
          <h3 class="font-heading text-lg font-semibold text-content">Adhérer</h3>
          <p class="mt-2 text-sm text-content/70">
            L'adhésion est de <strong>10 € minimum</strong>, de date à date. En
            rejoignant <ToulibreName />, vous soutenez la promotion du logiciel libre
            en Occitanie et participez à la vie de l'association.
          </p>
          <a
            href="/adhesion"
            class="mt-4 inline-flex items-center gap-2 rounded-full bg-orange px-5 py-2.5 font-heading text-sm font-semibold text-black transition-colors hover:bg-yellow"
          >
            En savoir plus
          </a>
        </div>
      </div>
    </div>
  </Section>

  <!-- ====== COMMUNITY ====== -->
  <Section
    id="communaute"
    title="Rejoignez la communauté"
    subtitle="Plusieurs canaux pour échanger, poser vos questions et suivre nos actualités."
    dark
  >
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <!-- Mailing lists -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-orange/20">
          <svg
            class="h-5 w-5 text-orange"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </div>
        <h3 class="font-heading text-lg font-semibold text-white">Listes de diffusion</h3>
        <ul class="mt-3 space-y-2 text-sm" role="list">
          <li>
            <a href="https://toulibre.org/mailman/listinfo/toulibre-annonces/" target="_blank" rel="noopener noreferrer" class="text-orange underline decoration-orange/30 transition-colors hover:text-yellow">toulibre-annonces</a>
            <span class="text-white/50"> — Annonces événements (faible trafic)</span>
          </li>
          <li>
            <a href="https://toulibre.org/mailman/listinfo/toulouse-ll/" target="_blank" rel="noopener noreferrer" class="text-orange underline decoration-orange/30 transition-colors hover:text-yellow">toulouse-ll</a>
            <span class="text-white/50"> — Échanges et questions techniques</span>
          </li>
          <li>
            <a href="https://toulibre.org/mailman/listinfo/toulibre-orga/" target="_blank" rel="noopener noreferrer" class="text-orange underline decoration-orange/30 transition-colors hover:text-yellow">toulibre-orga</a>
            <span class="text-white/50"> — Organisation des événements</span>
          </li>
          <li>
            <a href="https://toulibre.org/mailman/listinfo/capitoledulibre/" target="_blank" rel="noopener noreferrer" class="text-orange underline decoration-orange/30 transition-colors hover:text-yellow">capitoledulibre</a>
            <span class="text-white/50"> — Organisation du Capitole du Libre</span>
          </li>
        </ul>
      </div>

      <!-- IRC -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-orange/20">
          <svg
            class="h-5 w-5 text-orange"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <h3 class="font-heading text-lg font-semibold text-white">IRC</h3>
        <p class="mt-3 text-sm text-white/50">
          Retrouvez-nous sur le canal
          <code class="rounded bg-white/10 px-1.5 py-0.5 text-orange">#toulibre</code>
          du réseau <strong class="text-white/70">Libera.Chat</strong>.
        </p>
        <p class="mt-2 text-sm text-white/50">
          Pour discuter en temps réel avec la communauté, poser une question ou simplement
          dire bonjour.
        </p>
      </div>

      <!-- Social media -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-orange/20">
          <svg
            class="h-5 w-5 text-orange"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line>
            <line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line>
          </svg>
        </div>
        <h3 class="font-heading text-lg font-semibold text-white">Réseaux sociaux</h3>
        <p class="mt-3 text-sm text-white/50">
          Suivez notre actualité et partagez la culture du libre.
        </p>
        <SocialLinks class="mt-4" iconClass="h-6 w-6" />
      </div>
    </div>

    <!-- Contact -->
    <div class="mt-12 text-center">
      <p class="text-white/50">
        Une question ? Une idée ? Envie de contribuer ?
      </p>
      <ObfuscatedEmail
        user="contact"
        domain="toulibre.org"
        class="mt-4 inline-flex items-center gap-2 rounded-full border border-orange px-6 py-3 font-heading text-sm font-semibold text-orange transition-colors hover:bg-orange hover:text-black"
      />
    </div>
  </Section>
</Layout>
